# Django LMS Environment Configuration
# Copy this file to .env and update with your values

# Django Settings
SECRET_KEY=generate-a-secure-random-key-here
DEBUG=False

# Base URL (MUST CHANGE FOR PRODUCTION)
# For local: http://localhost:8000
# For PythonAnywhere: https://yourusername.pythonanywhere.com
BASE_URL=https://your-domain.com

# =============================================================================
# SSLCommerz Payment Settings
# =============================================================================

# SANDBOX MODE (Testing) - Default
# Use these test credentials for sandbox testing:
SSLCOMMERZ_STORE_ID=test
SSLCOMMERZ_STORE_PASSWORD=qwerty
SSLCOMMERZ_SANDBOX=True

# PRODUCTION MODE (Live Payments)
# To accept real payments:
# 1. Register at https://www.sslcommerz.com/
# 2. Get your Store ID and Store Password
# 3. Set SSLCOMMERZ_SANDBOX=False
# 4. Replace the values below with your real credentials:
# SSLCOMMERZ_STORE_ID=your_real_store_id
# SSLCOMMERZ_STORE_PASSWORD=your_real_store_password
# SSLCOMMERZ_SANDBOX=False

# =============================================================================
# Email Settings
# =============================================================================

# For local development - emails are printed to console:
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production - use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=your-email@gmail.com

# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Create an App Password at: https://myaccount.google.com/security
# 3. Use the app password as EMAIL_HOST_PASSWORD

# =============================================================================
# GENERATE SECRET KEY
# =============================================================================
# Run this command to generate a secure key:
# python -c "from django.core.management.utils import get_random_secret_key(); print(get_random_secret_key())"
